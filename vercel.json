{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/dream",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/daily-tweet",
      "schedule": "0 12 * * *"
    }
  ],
  "experimentalServices": {
    "web": {
      "entrypoint": ".",
      "framework": "nextjs",
      "routePrefix": "/"
    },
    "eve": {
      "buildCommand": "eve build",
      "entrypoint": ".",
      "framework": "eve",
      "routePrefix": "/_eve_internal/eve"
    }
  }
}
